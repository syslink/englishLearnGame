# ---- Vercel Prisma Postgres ----
# 在 Vercel Dashboard → Storage → 创建 Prisma Postgres 后，会注入三个变量
# （前缀可能是 flyword_ / PRISMA_ 等，取决于 integration 名称）：
#   flyword_DATABASE_URL         → 直连 postgres://...@db.prisma.io
#   flyword_POSTGRES_URL         → 同上（别名）
#   flyword_PRISMA_DATABASE_URL  → prisma+postgres://accelerate.prisma-data.net/...
#
# 本项目使用方式：
#   DATABASE_URL  → 运行时查询（走 Accelerate HTTP 接口，serverless 下连接池友好）
#   DIRECT_URL    → prisma db push / migrate 用（直连 DB，绕过 Accelerate）
#
# 本地开发：在 Vercel 项目里跑 `vercel env pull .env.local`，
# 然后把 flyword_PRISMA_DATABASE_URL 值复制到 DATABASE_URL，
# 把 flyword_DATABASE_URL 值复制到 DIRECT_URL。

DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_ACCELERATE_KEY"
DIRECT_URL="postgres://user:pass@db.prisma.io:5432/postgres?sslmode=require"

# ---- JWT Session Secret ----
# 必须至少 32 字符。生成方式：openssl rand -base64 48
AUTH_SECRET="请替换为至少32字符的随机字符串_change_me_change_me_change_me"

# ---- Vercel Blob（用户头像等图片存储）----
# 在 Vercel Dashboard → Storage → 创建 Blob 后，Vercel 会自动注入 BLOB_READ_WRITE_TOKEN
# 到项目环境变量；本地开发 `vercel env pull .env.local` 也会带上。
# 未配置时头像将无法上传（注册仍可继续，但 avatar 字段为 null）。
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx_yyy"

# ---- 云端大模型：OpenAI ----
# 密钥只放在服务端环境变量中，浏览器端只会看到 provider 是否已配置和默认模型。

OPENAI_API_KEY="sk-xxx"
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_CHAT_MODEL="gpt-4o-mini"

# ---- 云端大模型：DeepSeek ----

DEEPSEEK_API_KEY="sk-xxx"
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
DEEPSEEK_CHAT_MODEL="deepseek-chat"

# ---- OpenAI 音频服务（TTS / STT）----
# OPENAI_TTS_MODEL="gpt-4o-mini-tts"
# OPENAI_STT_MODEL="whisper-1"
# OPENAI_TTS_VOICE="marin"
